[internationalization]

locale/translations_pot_files=PackedStringArray("res://addons/dialogue_manager/dialogue_file/generated/hstory_demo.dialogue", "res://addons/dialogue_manager/dialogue_file/global.dialogue", "res://addons/dialogue_manager/dialogue_file/stage1.dialogue", "res://addons/dialogue_manager/dialogue_file/stage2.dialogue", "res://addons/dialogue_manager/dialogue_file/stage3.dialogue", "res://addons/dialogue_manager/dialogue_file/stage4.dialogue", "res://addons/dialogue_manager/dialogue_file/stage5.dialogue", "res://addons/dialogue_manager/modify_test/demo/demo_dialogue.dialogue", "res://addons/dialogue_manager/modify_test/demo/illustration_test.dialogue", "res://addons/dialogue_manager/modify_test/demo/scene1_tutorial.dialogue", "res://addons/dialogue_manager/modify_test/demo/scene2_characters.dialogue", "res://addons/dialogue_manager/modify_test/demo/scene3_branch.dialogue", "res://addons/dialogue_manager/modify_test/demo/scene3_branches.dialogue", "res://dialogue/closeai_stage1.dialogue", "res://dialogue/closeai_stage2.dialogue", "res://dialogue/closeai_stage3.dialogue")

[physics]

