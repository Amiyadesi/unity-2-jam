; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CloseAI"
config/description="一个关于关闭的游戏。关闭它，才能救它。"
run/main_scene="res://scenes/boot.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

SaveSystem="*uid://bv1y5o6lgq7yi"
SceneManager="*res://addons/scene_manager/autoload/scene_manager.tscn"
GuiTransitions="*uid://lbwvyqfdnu7x"
SoundManager="*uid://b2wllo35vbjaj"
DialogueManager="*uid://c3rodes2l3gxb"
GameFlow="*res://scripts/autoload/game_flow.gd"
InfoFlow="*res://scripts/autoload/info_flow.gd"

[debug]

gdscript/warnings/unused_parameter=0
gdscript/warnings/unused_signal=0

[dialogue_manager]

runtime/balloon_path="res://addons/dialogue_manager/modify_test/modular_balloon.tscn"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=3
window/stretch/mode="canvas_items"
window/per_pixel_transparency/allowed=true

[dotnet]

project/assembly_name="CloseAI"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg", "res://addons/enhance_save_system/plugin.cfg", "res://addons/phantom_camera/plugin.cfg", "res://addons/richtext2/plugin.cfg", "res://addons/scene_manager/plugin.cfg", "res://addons/simple-gui-transitions/plugin.cfg", "res://addons/sound_manager/plugin.cfg")

[gui_transitions]

config/default/auto_start=true
config/default/fade_layout=true
config/default/center_pivot=true
config/default/duration=0.5
config/default/delay=0.3
config/default/transition_type="QUAD"
config/default/ease_type="IN_OUT"
config/default/animation_enter=4
config/default/animation_leave=4

