# Copy this file to .env, then fill in your Unity2.Ai key.
# Keep .env local. Never commit real keys.

# Pick the default profile used by tools/unity2_smoke_test.py.
UNITY2_PROFILE=codex

# Shared Unity2.Ai gateway settings. If the dashboard shows another base URL,
# replace this value before running the smoke test.
UNITY2_BASE_URL=https://api.unity2.ai/v1

# Codex key/profile.
UNITY2_CODEX_API_KEY=replace_with_your_codex_key
UNITY2_CODEX_MODEL=

# Claude Code key/profile.
UNITY2_CLAUDE_CODE_API_KEY=replace_with_your_claude_code_key
UNITY2_CLAUDE_CODE_MODEL=

# Legacy single-key fallback. Keep empty unless you only have one key.
UNITY2_API_KEY=
UNITY2_MODEL=
